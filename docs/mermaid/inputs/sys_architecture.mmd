%% Requires Mermaid v10.6+ (architecture-beta diagram type)
architecture-beta
    group client(cloud)[Client Layer]
    service browser(cloud) in client
    service vite-dev-server(server) in client

    group backend(cloud)[Backend Layer]
    service flask-api(server) in backend
    service qa-service(server) in backend
    service rag-workflow(server) in backend
    service rag-repo(server) in backend
    service retrieval-workflow(server) in backend
    service search-engine(server) in backend
    service reranker(server) in backend
    service persist-message(server) in backend

    group data(cloud)[Data Layer]
    service mongodb(disk) in data
    service file-indexes(disk) in data
    service flattened-json(disk) in data
    service synonyms(disk) in data

    group llm(cloud)[LLM Layer]
    service ollama(server) in llm

    browser:R -- L:flask-api
    vite-dev-server:R -- L:flask-api
    flask-api:L -- R:qa-service
    flask-api:T -- B:persist-message
    qa-service:B -- T:rag-workflow
    rag-workflow:B -- T:rag-repo
    rag-repo:B -- T:retrieval-workflow
    retrieval-workflow:L -- R:search-engine
    retrieval-workflow:R -- L:reranker
    rag-repo:R -- L:ollama
    search-engine:T -- B:file-indexes
    search-engine:B -- T:synonyms
    persist-message:B -- T:mongodb
    flattened-json:R -- L:file-indexes
