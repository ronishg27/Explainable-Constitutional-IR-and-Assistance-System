flowchart TD
    Start(["User Query"]) --> Validate{"Valid & ≤500 chars?"}
    Validate -->|No| Bad(["400: Bad Request"])
    Validate -->|Yes| Auth{"JWT valid?"}
    Auth -->|No| UnAuth(["401: Unauthorized"])
    Auth -->|Yes| LLM{"use_llm?"}

    LLM -->|No| Search["SearchEngine.search(recall_k=30)"]
    LLM -->|Yes| Check["Check Ollama Availability"]

    Check -->|Down| Down(["503: Unavailable"])
    Check -->|Up| Model{"Model exists?"}
    Model -->|No| Search
    Model -->|Yes| Full["RAGWorkflow.ask()"]

    Search --> Score["Multi-strategy Scoring<br/>BM25 + Proximity + Title"]
    Score --> Top["Top-30 → Rerank → Top-8"]
    Top --> Promote["Article Promotion<br/>(clause→article, dedup)"]
    Promote --> Persist["Persist to MongoDB"]

    Full --> FullSearch["Search + Rerank + Promote"]
    FullSearch --> Format["Build context & prompt"]
    Format --> LLMCall["Ollama.chat (3× retry)"]
    LLMCall --> OK{"Success?"}
    OK -->|Yes| Return(["200: Answer + Articles"])
    OK -->|No| Err(["200: Error + Articles"])

    Persist --> RetOnly(["200: Articles Only"])
