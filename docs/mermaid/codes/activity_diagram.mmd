flowchart LR
    subgraph OFFLINE["Offline — Data Ingestion"]
        direction TB
        O1["1. Constitution JSON"] --> O2["2. Flattened JSON documents"]
        O2 --> O3["3. NLP Processing<br/>(two configs)"]
        O3 --> O4["4. Lemma Dictionary"]
        O3 --> O5["4. Compute Statistics<br/>(TF, doc length, avgdl)"]
        O5 --> O6["5. Inverted Index<br/>tf_index.json"]
        O5 --> O7["5. Positional Index<br/>pos_index.json"]
    end

    subgraph ONLINE["Online — Q&A Retrieval"]
        direction TB
        A["1. Receive user query"] --> B["2. NLP Processing<br/>(BM25 + Proximity)"]
        B --> C["3. Query Expansion<br/>(44 synonym groups)"]
        C --> D["4. Score: BM25 + Proximity + Title ×5"]
        D --> E["5. Sort top-50"]
        E --> F["6. Rerank top-8<br/>(RRF + MMR + Rule)"]
        F --> G["7. Article Promotion<br/>(merge + dedup)"]
        G --> H{"8. LLM mode?"}
        H -->|No| I["9. Persist to MongoDB"]
        H -->|Yes| J["8. Truncate → Format → Ollama"]
        J --> K{"Success?"}
        K -->|Yes| I
        K -->|No| I
        I --> L["10. Send response"]
    end

    O6 -.->|"read"| D
    O7 -.->|"read"| D
    O4 -.->|"used"| B
